# Copia este archivo a .env.local y coloca tus valores reales.
# Las variables SIN prefijo NEXT_PUBLIC solo viven en el servidor (nunca en el cliente).

# ── LLM (chatbot) ────────────────────────────────────────────────
# Se usa solo en /app/api/chat/route.ts. Sin esta clave, el chat funciona en modo local.
ANTHROPIC_API_KEY=sk-ant-...
# Modelo configurable (opcional). Por defecto: claude-sonnet-4-6
ANTHROPIC_MODEL=claude-sonnet-4-6

# ── Login ────────────────────────────────────────────────────────
# Credenciales de acceso. Si no las defines, se usan los valores por defecto del código
# (usuario "revisor" / contraseña "Mesia2025").
APP_USER=revisor
APP_PASSWORD=Mesia2025
# Secreto de sesión: cámbialo por una cadena larga y aleatoria en producción.
AUTH_SECRET=cambia-esto-por-un-secreto-largo-y-aleatorio
